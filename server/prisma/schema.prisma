generator client {
  provider   = "prisma-client-js"
  engineType = "client"
  runtime    = "workerd"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String             @id
  name            String
  email           String             @unique
  emailVerified   Boolean
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  transactions    Transaction[]
  accounts        Account[]
  sessions        Session[]
  categories      Category[]
  balances        Balance[]
  budgets Budget[]
  pendingBudgets PendingBudget[]
  pendingTransactions PendingTransaction[]
  userPreferences User_Preferences[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Category {
  id           Int           @id @default(autoincrement())
  userId       String? //If null => default global category
  name         String
  type         CategoryType
  description  String?
  user         User?         @relation(fields: [userId], references: [id])
  transactions Transaction[]
  budgets Budget[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId, name, type])
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  categoryId  Int?
  amount      String
  currency    SupportedCurrency @default(AUD)
  isRecurring Boolean @default(false)
  pendingTransactions PendingTransaction[]
  description String?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id])
  category    Category?         @relation(fields: [categoryId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, categoryId])
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum SupportedCurrency {
  USD
  AUD
  VND
}

model Balance {
  id       String            @id @default(uuid())
  userId   String            @unique
  amount   String            @default("0")
  currency SupportedCurrency
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User_Preferences {
  id          Int               @id @default(autoincrement())
  userId      String            @unique
  currency    SupportedCurrency @default(AUD)
  avatar      String?
  theme       String            @default("light")
  isSetupDone Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BudgetDuration {
  WEEK_1
  WEEK_2
  MONTH_1
  MONTH_3
  MONTH_6
  MONTH_12
}

model Budget {
  id String @id @default(cuid())
  userId String
  categoryId Int?
  name String?
  amount String
  currency SupportedCurrency @default(AUD)
  duration BudgetDuration @default(MONTH_1)
  isRecurring Boolean @default(false)
  isRollOver Boolean @default(false)
  startDate DateTime
  endDate DateTime

  parentBudgetId String?
  parentBudget Budget? @relation("BudgetRecurrence", fields: [parentBudgetId], references: [id])
  childBudget Budget[] @relation("BudgetRecurrence")

  pendingBudgets PendingBudget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([userId, categoryId])
  @@index([isRecurring, endDate])
}

enum PendingJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model PendingBudget {
  id String @id @default(cuid())
  userId String
  budgetId String

  status PendingJobStatus @default(PENDING)

  scheduledAt DateTime
  processedAt DateTime?
  failedAt DateTime?
  failReason String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([userId])
}

model PendingTransaction {
  id String @id @default(cuid())
  userId String
  transactionId String

  status PendingJobStatus @default(PENDING)

  scheduledAt DateTime
  processedAt DateTime?
  failedAt DateTime?
  failReason String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([status, scheduledAt])
  @@index([userId])
}