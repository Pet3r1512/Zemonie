{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zemonie-server",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-14",
  "compatibility_flags": ["nodejs_compat"],

  "routes": [
    {
      "pattern": "api.zemonie.site",
      "custom_domain": true,
    },
  ],

  "ratelimits": [
    {
      "binding": "ZEMONIE_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 100,
        "period": 60,
      },
    },
  ],

  "vars": {
    "NODE_ENV": "production",
    "PORT": "9999",
    "LOG_LEVEL": "info",
    "BETTER_AUTH_URL": "https://zemonie.site",
    "TRUSTED_ORIGIN": "https://zemonie.site",
    "BASE_URL": "https://api.zemonie.site",
  },

  "triggers": {
    "crons": ["*/5 * * * *"],
  },
}
