    "@types/node": "^20.17.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/browser": "3.2.3",
    "@vitest/coverage-istanbul": "^3.2.6",
    "@vitest/coverage-v8": "^2.1.3",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "playwright": "^1.53.0",
    "postcss": "^8.4.47",
    "storybook": "^9.0.10",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.6.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.3",
    "wrangler": "^4.80.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix --ignore-path ../.oxlintignore",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{json,css,md}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
